{
  "name": "invoiceflow",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "ln -sfn ../apps/mobile/node_modules/expo-router node_modules/expo-router 2>/dev/null || true && pnpm -F api db:generate 2>/dev/null || true",
    "api": "pnpm -F api start:dev",
    "mobile": "pnpm -F mobile start",
    "admin": "pnpm -F admin dev",
    "db:up": "docker compose up -d",
    "db:seed": "pnpm -F api db:seed",
    "setup": "docker compose up -d && pnpm -F api db:push && pnpm -F api db:seed",
    "dev:api": "pnpm -F api start:dev",
    "dev:mobile": "pnpm -F mobile start:dev",
    "dev:mobile:android": "pnpm -F mobile android",
    "dev:mobile:ios": "pnpm -F mobile ios",
    "dev:admin": "pnpm -F admin dev",
    "render:build:api": "bash scripts/render-build-api.sh",
    "render:build:admin": "bash scripts/render-build-admin.sh",
    "render:start:api": "pnpm -F api start:prod",
    "render:start:admin": "pnpm -F admin start"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.3",
      "react-dom": "19.2.3",
      "react-native-svg": "15.15.4",
      "react-native-worklets": "0.8.3",
      "react-native-reanimated": "4.3.1",
      "expo-constants": "~56.0.18",
      "expo-asset": "~56.0.17"
    }
  },
  "dependencies": {
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native-reanimated": "4.3.1",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@nestjs/platform-express": "^11.1.27",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  }
}
