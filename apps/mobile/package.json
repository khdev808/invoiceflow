{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.101.1",
    "axios": "^1.18.1",
    "date-fns": "^4.4.0",
    "expo": "~56.0.12",
    "expo-asset": "~56.0.17",
    "expo-constants": "~56.0.18",
    "expo-contacts": "~56.0.9",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-haptics": "^56.0.3",
    "expo-image-picker": "~56.0.18",
    "expo-linear-gradient": "^56.0.4",
    "expo-linking": "~56.0.14",
    "expo-local-authentication": "~56.0.4",
    "expo-localization": "~56.0.6",
    "expo-notifications": "~56.0.18",
    "expo-print": "~56.0.4",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.18",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-web-browser": "~56.0.5",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "^15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "setup:android": "bash scripts/setup-android-dev.sh",
    "start": "APP_VARIANT=development expo start",
    "start:dev": "APP_VARIANT=development expo start",
    "start:prod": "APP_VARIANT=production expo start",
    "dev:mobile": "npm run start:dev",
    "dev:mobile:android": "npm run android",
    "dev:mobile:ios": "npm run ios",
    "android": "npm run setup:android && APP_VARIANT=development expo start --android --localhost --clear",
    "android:prod": "npm run setup:android && APP_VARIANT=production expo start --android --localhost",
    "ios": "APP_VARIANT=development expo start --ios --clear",
    "ios:prod": "APP_VARIANT=production expo start --ios",
    "web": "expo start --web",
    "build:dev:ios": "APP_VARIANT=development eas build --profile development --platform ios",
    "build:dev:android": "APP_VARIANT=development eas build --profile development --platform android",
    "build:prod:ios": "APP_VARIANT=production eas build --profile production --platform ios",
    "build:prod:android": "APP_VARIANT=production eas build --profile production --platform android"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "react-native-reanimated",
        "react-native-worklets"
      ]
    }
  }
}
