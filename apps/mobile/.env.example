# Optional overrides (defaults point at Render production)
# EXPO_PUBLIC_API_URL=https://invoiceflow-api-v1td.onrender.com
# EXPO_PUBLIC_PORTAL_URL=https://invoiceflow-admin.onrender.com/portal

# EAS (set after eas init)
# EAS_PROJECT_ID=
# EXPO_OWNER=your-expo-username

# Must match API MOBILE_APP_KEY (bypasses Turnstile on mobile login)
# EXPO_PUBLIC_MOBILE_APP_KEY=

# RevenueCat native IAP (optional — see IAP_SETUP.md; falls back to Stripe checkout)
# EXPO_PUBLIC_REVENUECAT_APPLE_KEY=
# EXPO_PUBLIC_REVENUECAT_GOOGLE_KEY=
